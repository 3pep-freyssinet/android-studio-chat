<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="com.example.aymen.androidchat.FragmentExemple">

<!-- image profile -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.05"
        android:orientation="horizontal">

        <View
            android:id="@+id/view_separator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8" />

        <!-- 'iv_parameter' is replaced by menu. So it is here but invisible -->
        <ImageView
            android:id="@+id/iv_parameter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="right"
            android:layout_weight="0.2"
            android:visibility="invisible"
            android:src="@drawable/cancel_enabled" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_image_profile"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp"
        android:layout_weight="0.35"
        android:background="#004CAF50"
        android:gravity="center_vertical|center_horizontal"
        android:orientation="vertical">
        <!--  -->
        <ImageView
            android:id="@+id/image_profile"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:src="@drawable/avatar" />
    </LinearLayout>

    <!-- buttons image profile -->
    <LinearLayout
        android:id="@+id/ll_buttons_image_profile"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@+id/image_profile"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginRight="0dp"
        android:layout_weight="0.1"
        android:gravity="center_vertical|center_horizontal"
        android:background="#00ffff00"
        android:orientation="horizontal">

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909" />

        <ImageView
            android:id="@+id/iv_camera_"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909"
            android:adjustViewBounds="true"
            android:src="@drawable/camera_50_gray" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909" />

        <ImageView
            android:id="@+id/iv_gallery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909"
            android:adjustViewBounds="true"
            android:src="@drawable/gallery_64_gray" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909" />

        <ImageView
            android:id="@+id/iv_folder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909"
            android:adjustViewBounds="true"
            android:src="@drawable/folder_50_gray" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909" />

        <ImageView
            android:id="@+id/iv_history"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909"
            android:adjustViewBounds="true"
            android:src="@drawable/history_64_gray" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909" />

        <ImageView
            android:id="@+id/iv_delete"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909"
            android:adjustViewBounds="true"
            android:src="@drawable/delete_64_gray" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909" />

    </LinearLayout>

    <!-- edt -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:layout_weight="0.25"
        android:background="#0000ffff"
        android:orientation="vertical">

        <EditText
            android:id="@+id/nickname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/ll_buttons_image_profile"
            android:layout_marginTop="10dp"
            android:hint="Enter your name !"
            android:textSize="30dp" />

        <Button
            android:id="@+id/enter_chat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/nickname"
            android:layout_marginTop="10dp"
            android:text="Go to derda_chat " />

    </LinearLayout>

    <!-- not seen images -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="0dp"
        android:layout_below="@+id/enter_chat"
        android:layout_marginBottom="10dp"
        android:layout_weight="0.30"
        android:background="#00ff00ff"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tv_not_seen_messages_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Not seen messages : 0" />
        <FrameLayout
            android:id="@+id/ll_not_seen_messages"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:background="#00ffff00" />
    </LinearLayout>

    <!-- flottant action button
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/fab_margin"
        android:layout_marginBottom="16dp"
        app:srcCompat="@android:drawable/ic_dialog_email" />
        -->

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical" >

    <!--   android:layout_height="370dip" -->
    <com.google.amara.chattab.Panel
        android:id="@+id/panel"
        android:layout_weight="0.9"
        android:layout_width="wrap_content"
        android:layout_height="0dip" />
    
	<LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="0dip"
        android:layout_weight="0.1"
        android:weightSum="10"
        android:orientation="horizontal">
        
        <TextView
        android:id="@+id/display"
        android:layout_width="0dip"
        android:layout_height="fill_parent"
        android:layout_weight="4"
        android:background="@drawable/customborder"
        android:textColor="@color/colorCyan"
        android:textAlignment="center"
        android:text="TextView" />
         
         <!--    
        <com.google.amara.canvas_tutorial.ChronoView
        android:id="@+id/panel1"
        android:layout_width="0dip"
        android:layout_height="50dip" 
        android:layout_weight="0.250"/>
        -->
        
        <fragment
        	android:id="@+id/fragment" 
			android:layout_width="0dip"
			android:layout_height="wrap_content"
			android:layout_weight="3"
			android:name="com.google.amara.chattab.ClockFragment"
			android:orientation="horizontal" >
        </fragment>
        
    	<Button
        android:id="@+id/backward_button"
        android:layout_width="0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1"
		android:background="@drawable/button_back_custom"/>
        <!--      android:text=" B "-->
    	
     	<Button
        android:id="@+id/forward_button"
        android:layout_width="0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1"
		android:background="@drawable/button_head_custom"/>
		<!--  android:text=" F "-->

         <Button
        android:id="@+id/cancel_button"
        android:layout_width="0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1"
		 android:background="@drawable/button_cancel_custom"/>
		<!-- android:background="@drawable/button_cancel_custom" android:text=" C "-->
    </LinearLayout>
</LinearLayout>
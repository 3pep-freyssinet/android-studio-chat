<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- android:background="@color/colorYellow"-->

    <!-- 🔝 HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#EEEEEE"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Avatar + Status -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">

            <ImageView
                android:id="@+id/header_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_launcher"
                android:scaleType="centerCrop"
                android:background="@drawable/rounded_shape"/>

            <!-- 🟢 Online badge -->
            <View
                android:id="@+id/status_badge"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="top|start"
                android:background="@drawable/bg_online_dot"/>
        </FrameLayout>

        <!-- Text block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Name -->
            <TextView
                android:id="@+id/header_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fanny"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <!-- status: pending, accept, reject friendship -->
            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="13sp"
                android:textColor="#666"/>
            <!-- Last seen -->
            <TextView
                android:id="@+id/header_last_seen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last seen: --"
                android:textSize="12sp"
                android:textColor="#666666"/>

            <!-- Connected -->
            <TextView
                android:id="@+id/header_connected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connected: --"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

    </LinearLayout>
    <!-- end header -->

    <!-- 🔥 STATE CONTAINER -->
    <FrameLayout
        android:id="@+id/state_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/recycler_messages"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Pending -->
        <LinearLayout
            android:id="@+id/pendingLayout"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_pending"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏳ Waiting for response..."/>

    </LinearLayout>

    <!-- Rejected -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/rejectedLayout"
        android:visibility="gone">

    <TextView
        android:id="@+id/tv_rejected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❌ Request rejected"/>

</LinearLayout>

    </FrameLayout>

    <!-- 💬 RECYCLER VIEW -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_messages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/state_container"
        app:layout_constraintBottom_toTopOf="@id/input_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="No messages yet 👋"
        android:gravity="center"
        android:textSize="16sp"
        android:visibility="gone"/>

    <!-- ✏️ INPUT AREA -->
    <LinearLayout
        android:id="@+id/input_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Message">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edt_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_send"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/ic_launcher" />

            <ImageView
                android:id="@+id/iv_attach"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/ic_launcher" />

            <ImageView
                android:id="@+id/iv_camera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/ic_launcher" />

        </LinearLayout>

        <!-- Preview -->
        <LinearLayout
            android:id="@+id/ll_attachment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/preview_image"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:scaleType="centerCrop"
                android:background="@drawable/rounded_shape" />
            <ImageView
                android:id="@+id/btn_remove_image"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@android:color/holo_red_dark"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.aymen.androidchat.FragmentExemple">

    <EditText
        android:id="@+id/nickname"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/ll_buttons_image_profile"
        android:layout_marginTop="30dp"
        android:hint="Enter your name !"
        android:textSize="30dp" />

    <Button
        android:id="@+id/enter_chat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/nickname"
        android:layout_marginTop="30dp"
        android:text="Go to derda_chat " />

    <ImageView
        android:id="@+id/image_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_marginStart="100dp"
        android:layout_marginLeft="100dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="100dp"
        android:layout_marginRight="100dp"
        android:adjustViewBounds="true"
        android:src="@drawable/avatar" />

    <LinearLayout
        android:id="@+id/ll_buttons_image_profile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/image_profile"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="0dp"
        android:layout_marginRight="0dp"
        android:orientation="horizontal">

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909" />

        <ImageView
            android:id="@+id/iv_camera_"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909"
            android:adjustViewBounds="true"
            android:src="@drawable/camera_50_gray" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909" />

        <ImageView
            android:id="@+id/iv_gallery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909"
            android:adjustViewBounds="true"
            android:src="@drawable/gallery_64_gray" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909" />

        <ImageView
            android:id="@+id/iv_folder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909"
            android:adjustViewBounds="true"
            android:src="@drawable/folder_50_gray" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909" />

        <ImageView
            android:id="@+id/iv_history"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909"
            android:adjustViewBounds="true"
            android:src="@drawable/history_64_gray" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909" />

        <ImageView
            android:id="@+id/iv_delete"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909"
            android:adjustViewBounds="true"
            android:src="@drawable/delete_64_gray" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.909" />

    </LinearLayout>

    <!-- not seen images -->
    <FrameLayout
        android:id="@+id/ll_not_seen_messages"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/enter_chat"
        android:layout_marginTop="20dp"
        android:background="@color/colorYellow" >

        <TextView
            android:id="@+id/textView_register"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TextView" />
    </FrameLayout>

</RelativeLayout>
